{
  "name": "@ntnyq/eslint-config",
  "type": "module",
  "version": "7.0.0-beta.11",
  "packageManager": "pnpm@11.11.0",
  "description": "An opinionated ESLint config preset of ntnyq",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-flat-config",
    "ntnyq"
  ],
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "homepage": "https://eslint-config.ntnyq.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ntnyq/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/ntnyq/eslint-config/issues"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "scripts": {
    "build": "run-s types:generate lib:build",
    "dev": "run-s types:generate lib:dev",
    "docs:build": "pnpm -C docs run build",
    "docs:dev": "pnpm -C docs run dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "inspector:build": "run-s build inspector:generate",
    "inspector:generate": "pnpm dlx @eslint/config-inspector build --config eslint-inspector.config.ts",
    "lib:build": "tsdown",
    "lib:dev": "tsdown --watch",
    "lint": "eslint --cache",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-s build format:check lint test typecheck",
    "release:version": "bumpp",
    "test": "vitest",
    "typecheck": "tsgo --noEmit",
    "types:generate": "tsx scripts/generateType.ts"
  },
  "peerDependencies": {
    "@html-eslint/eslint-plugin": "^0.64.0",
    "@html-eslint/parser": "^0.64.0",
    "astro-eslint-parser": "^3.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^3.0.0",
    "eslint-plugin-eslint-plugin": "^7.4.2",
    "eslint-plugin-pnpm": "^1.6.1",
    "eslint-plugin-svelte": "^3.20.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "svelte": "^5.56.4",
    "svelte-eslint-parser": "^1.8.0"
  },
  "peerDependenciesMeta": {
    "@html-eslint/eslint-plugin": {
      "optional": true
    },
    "@html-eslint/parser": {
      "optional": true
    },
    "astro-eslint-parser": {
      "optional": true
    },
    "eslint-plugin-astro": {
      "optional": true
    },
    "eslint-plugin-eslint-plugin": {
      "optional": true
    },
    "eslint-plugin-pnpm": {
      "optional": true
    },
    "eslint-plugin-svelte": {
      "optional": true
    },
    "eslint-plugin-unused-imports": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "svelte-eslint-parser": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/install-pkg": "^1.1.0",
    "@clack/prompts": "^1.7.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.3",
    "@ntnyq/utils": "^0.16.0",
    "@unocss/eslint-plugin": "^66.7.5",
    "@vitest/eslint-plugin": "^1.6.23",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-flat-config-utils": "^3.2.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-merge-processors": "^2.0.0",
    "eslint-parser-plain": "^0.1.1",
    "eslint-plugin-antfu": "^3.2.3",
    "eslint-plugin-command": "^3.5.2",
    "eslint-plugin-de-morgan": "^2.1.3",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-github-action": "^0.3.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.13",
    "eslint-plugin-jsonc": "^3.3.0",
    "eslint-plugin-n": "^18.2.2",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-ntnyq": "^0.14.0",
    "eslint-plugin-oxfmt": "^0.13.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-pinia": "^0.4.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-svgo": "^0.12.0",
    "eslint-plugin-toml": "^1.4.0",
    "eslint-plugin-unicorn": "^71.1.0",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-yml": "^3.6.0",
    "eslint-processor-vue-blocks": "^2.0.0",
    "globals": "^17.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "local-pkg": "^1.2.1",
    "toml-eslint-parser": "^1.0.3",
    "typescript-eslint": "^8.63.0",
    "vue-eslint-parser": "^10.4.1",
    "yaml-eslint-parser": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript-eslint/types": "^8.63.0",
    "@typescript-eslint/utils": "^8.63.0",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "bumpp": "^11.1.0",
    "consola": "^3.4.2",
    "eslint": "^10.7.0",
    "eslint-typegen": "^2.3.1",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.58.0",
    "prettier": "^3.9.5",
    "tinyglobby": "^0.2.17",
    "tsdown": "^0.22.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "uncase": "^0.2.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "^22.13.0 || >=24.11.0"
  },
  "nano-staged": {
    "*.{js,ts,tsx,mjs,md,vue,svg,yml,yaml,toml,json}": "eslint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
